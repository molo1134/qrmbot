# --- cache ---
sub cache_get {
  my $key = shift;
  our $cachedir;
  if (not -d $cachedir) {
    system ("mkdir -p $cachedir\n");
  }
  if (not -d $cachedir) {
    print "unable to make db directory $cachedir\n";
  }
  $key =~ s/[^a-zA-Z0-9_-]/_/g;
  my $f = "$cachedir/mlb_$key.json";
  return undef unless -f $f;
  my $age = time() - (stat($f))[9];
  return undef if $age > 30;
  open(my $fh, '<:utf8', $f) or return undef;
  local $/;
  my $d = <$fh>;
  close($fh);
  return $d;
}
sub cache_set {
  my ($key, $val) = @_;
  our $cachedir;
  if (not -d $cachedir) {
    system ("mkdir -p $cachedir\n");
  }
  if (not -d $cachedir) {
    print "unable to make db directory $cachedir\n";
  }
  $key =~ s/[^a-zA-Z0-9_-]/_/g;
  my $f = "$cachedir/mlb_$key.json";
  open(my $fh, '>:utf8', $f) or return;
  print $fh $val;
  close($fh);
}

sub fetchJSON {
  my ($url, $ckey) = @_;
  if ($ckey) {
    my $c = cache_get($ckey);
    return decode_json($c) if defined $c;
  }
  open(my $fh, '-|', "curl --max-time 10 -s -k -L -A \"$useragent\" '$url'");
  local $/;
  my $res = <$fh>;
  close($fh);
  return undef unless defined $res && length($res) > 2;
  cache_set($ckey, $res) if $ckey;
  return decode_json($res);
}

